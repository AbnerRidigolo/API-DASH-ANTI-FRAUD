# .env.example — copie para .env e preencha os valores reais
# NUNCA commite o .env no git

# ── API Mission Brasil (quando estiver pronta) ────────────────────────────────
MOCK_MODE=true
MISSION_API_URL=https://api.missionbrasil.com
MISSION_API_KEY=sua_chave_aqui

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8000
WORKERS=2
LOG_LEVEL=info

# ── Monitoramento ─────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=troque_esta_senha
